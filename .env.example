# GPX data source (required)
NEXT_PUBLIC_GPX_URL=https://cldt.hr/wp-content/uploads/2023/11/CLDT_Croatian_Long_Distance_Trail_2023_v1.gpx

# Cache version - bump to invalidate cached GPX
NEXT_PUBLIC_CACHE_VERSION=1

# Optional: override defaults (change without committing)
# NEXT_PUBLIC_DEFAULT_DIRECTION=SOBO
# NEXT_PUBLIC_DEFAULT_UNITS=metric
# NEXT_PUBLIC_DEFAULT_DISTANCE_PRECISION=2
# NEXT_PUBLIC_SHOW_BOUNDARY=false
# NEXT_PUBLIC_SHOW_TILE_BOUNDARY=false
# NEXT_PUBLIC_SHOW_USER_MARKER=true
# NEXT_PUBLIC_DEFAULT_BASE_MAP=OpenStreetMap
# NEXT_PUBLIC_DEFAULT_DARK_MODE=false
# NEXT_PUBLIC_DEFAULT_BATTERY_SAVER=false
# NEXT_PUBLIC_DEFAULT_LARGE_TOUCH_TARGETS=false
# NEXT_PUBLIC_DEFAULT_RULER_ENABLED=false
# NEXT_PUBLIC_DEFAULT_LOCALE=en
# NEXT_PUBLIC_DEFAULT_MAP_CENTER=44.4268,16.438
# NEXT_PUBLIC_DEFAULT_MAP_ZOOM=7
